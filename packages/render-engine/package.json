{
  "name": "@bookhelper/render-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Format-agnostic rendering runtime: viewport, page virtualization, coordinate mapping, zoom math, visible-page detection, overlay layers, scroll synchronization, page measurements. Consumes @bookhelper/reader-core; never imports a format adapter.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@bookhelper/reader-core": "workspace:*"
  },
  "devDependencies": {
    "@bookhelper/config": "workspace:*",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
