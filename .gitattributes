# Normalize all text files to LF in the repo, regardless of OS checkout.
* text=auto eol=lf

# Source
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf

# Shell / config
*.sh        text eol=lf
.editorconfig text eol=lf
.nvmrc      text eol=lf
.npmrc      text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
Dockerfile  text eol=lf

# Treat lockfiles as generated — don't show in PR diffs by default,
# and disable merge conflicts by always preferring `theirs` (regenerate via pnpm).
pnpm-lock.yaml -diff linguist-generated=true
package-lock.json -diff linguist-generated=true
yarn.lock -diff linguist-generated=true

# Binary assets
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.avif      binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.zip       binary
*.gz        binary
*.tgz       binary
*.mp4       binary
*.webm      binary

# Vendored
packages/*/dist/** linguist-generated=true
**/.next/** linguist-generated=true

# Linguist hints — keep stats honest.
docs/** linguist-documentation=true
*.md   linguist-documentation=true
