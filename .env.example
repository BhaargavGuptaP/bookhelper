# ──────────────────────────────────────────────────────────────────────────
# BookHelper environment template. Copy to `.env` and fill in.
# NEVER commit a real `.env`. Secrets are loaded per-app and validated at boot.
# ──────────────────────────────────────────────────────────────────────────

# General
NODE_ENV=development
LOG_LEVEL=debug

# ── core-api ────────────────────────────────────────────────────────────────
CORE_API_PORT=4000
# Public origin of the web app (CORS allow-list).
WEB_ORIGIN=http://localhost:3000

# Database (PostgreSQL). Matches docker-compose.yml defaults for local dev.
DATABASE_URL=postgres://bookhelper:bookhelper@localhost:5432/bookhelper

# Object storage. driver = "local" (dev) | "s3" (S3 / Cloudflare R2).
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=.storage
# Used when STORAGE_DRIVER=s3 (R2: set S3_ENDPOINT to your R2 endpoint).
S3_BUCKET=bookhelper
S3_REGION=auto
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Authentication (OIDC — WorkOS compatible). The API verifies JWTs against the
# provider's JWKS. Leave issuer empty in dev to run the API without auth wired.
OIDC_ISSUER=
OIDC_JWKS_URI=
OIDC_AUDIENCE=bookhelper

# ── web ─────────────────────────────────────────────────────────────────────
# Public base URL of core-api as seen by the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=BookHelper
