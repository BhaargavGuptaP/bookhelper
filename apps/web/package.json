{
  "name": "@bookhelper/web",
  "version": "0.1.0",
  "private": true,
  "description": "BookHelper web app — Next.js 15 (App Router, RSC, React 19). Shell, theme, foundation only in Sprint 1.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .next .turbo coverage"
  },
  "dependencies": {
    "@bookhelper/api-contracts": "workspace:*",
    "@bookhelper/design-tokens": "workspace:*",
