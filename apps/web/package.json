    "@bookhelper/reader-core": "workspace:*",
    "@bookhelper/reader-ui": "workspace:*",
    "@bookhelper/render-engine": "workspace:*",
    "@bookhelper/telemetry": "workspace:*",
    "@bookhelper/ui": "workspace:*",
    "@tanstack/react-query": "^5.62.7",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@bookhelper/config": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
