# Strict, reproducible installs across the monorepo.
auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
prefer-workspace-packages=true
link-workspace-packages=deep
save-workspace-protocol=rolling
# Engine checks are advisory — third-party packages occasionally publish
# overly-narrow `engines.node` (excluding odd-numbered current LTS, etc.).
# We pin the canonical Node via `.nvmrc` and verify in CI; we don't let a
# transitive package's engines field block a local install on a valid runtime.
engine-strict=false

# Pin the public npm registry. Some corporate proxies do not mirror every
# package we need (e.g. several @aws-sdk subpackages, pino-http, drizzle-kit),
# and we ship as OSS — npmjs.org is the source of truth. Local mirrors can
# override this in a user-level .npmrc.
registry=https://registry.npmjs.org/
